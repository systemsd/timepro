# =============================================================================
# Root .env.example
#
# Each app also has its own .env.example with the subset it needs. This root
# file is a single source of truth — copy values from here when filling in
# the per-app `.env.local` files (or use direnv/dotenvx to load everything).
# =============================================================================

# ----- Postgres -----
DATABASE_URL=postgres://timepro_app:timepro_app@localhost:5432/timepro
DATABASE_ADMIN_URL=postgres://timepro_admin:timepro_admin@localhost:5432/timepro

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- S3 (Minio in dev) -----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123
S3_BUCKET_SCREENSHOTS=timepro-screenshots
S3_BUCKET_EXPORTS=timepro-exports
S3_BUCKET_AGENT_UPDATES=timepro-agent-updates

# ----- KMS (dev: local fake, prod: aws kms) -----
KMS_MODE=local                                 # local | aws
KMS_KEY_ID=local-dev-key
KMS_LOCAL_MASTER_KEY=dev-master-key-change-me-32bytes!!

# ----- Email (MailHog in dev) -----
EMAIL_TRANSPORT=smtp                           # smtp | ses
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SES_REGION=us-east-1
EMAIL_FROM="TimePro <noreply@timepro.local>"

# ----- Auth / JWT -----
JWT_SIGNING_KEY_PRIMARY=dev-signing-key-rotate-me-please-32b
JWT_SIGNING_KEY_NEXT=
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_DAYS=30
AUTH_AGENT_ACCESS_TTL_SECONDS=3600
AUTH_AGENT_REFRESH_TTL_DAYS=90
AUTH_COOKIE_DOMAIN=localhost
AUTH_INTERNAL_SHARED_SECRET=dev-internal-shared-secret

# ----- API server -----
API_PORT=3001
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:3001
API_CORS_ORIGINS=http://localhost:3000

# ----- Web -----
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
INTERNAL_API_URL=http://localhost:3001

# ----- Realtime -----
REALTIME_PORT=3010

# ----- Worker / scheduler -----
QUEUES=screenshot.process,ingest.fanout,rollup.daily,rollup.weekly,rollup.monthly,rollup.hourly.live,notify.email,notify.push,export.timesheet,export.screenshots,retention.sweep,webhook.delivery,agent.maintenance
LEADER_LOCK_KEY=tf:scheduler:leader
LEADER_LOCK_TTL_MS=15000

# ----- Observability -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAMESPACE=timepro
# Error tracking (API). Leave SENTRY_DSN empty to disable (default) — set it in
# prod to turn on capture. SENTRY_TRACES_SAMPLE_RATE is 0–1 (default 0.1).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Interactive API docs at /docs (Scalar). Exposed ONLY when API_DOCS_PASSWORD is
# set (any env), always behind HTTP Basic auth with a DEDICATED credential (NOT
# the app login). Empty → /docs is not exposed anywhere. Set a value locally to
# view the docs; set a strong value in prod to expose them there.
API_DOCS_USER=docs
API_DOCS_PASSWORD=
LOG_LEVEL=debug

# ----- Desktop agent (only when developing locally) -----
TIMEPRO_API_URL=http://localhost:3001
TIMEPRO_UPDATES_URL=http://localhost:9000/timepro-agent-updates
TIMEPRO_LOG_DIR=
RUST_LOG=info,timepro=debug
