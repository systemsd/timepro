{
  "name": "@timepro/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "lint": "echo '[api] lint stub — wire @timepro/eslint-config later' && exit 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:int": "vitest run -c vitest.integration.config.ts",
    "gen:openapi": "tsx scripts/gen-openapi.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.1",
    "@fastify/sensible": "^6.0.0",
    "@fastify/under-pressure": "^9.0.0",
    "@fastify/websocket": "^11",
    "@sentry/node": "^10.63.0",
    "@timepro/db": "workspace:*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "jose": "^6.2.3",
    "pg": "^8.13.0",
    "pino-pretty": "^11.3.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@timepro/eslint-config": "workspace:*",
    "@timepro/tsconfig": "workspace:*",
    "@types/node": "^20.16.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
