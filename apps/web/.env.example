# Web (Next.js) env — copy to .env.local (gitignored). Next loads env from
# THIS directory (apps/web), not the monorepo root. NEXT_PUBLIC_* are inlined
# at dev/build start, so restart `next dev` after changing them.

# OpsCore base URL — target of the "Sign in with OpsCore" button and the
# desktop-auth bridge. No trailing slash.
#   prod: https://opscore.systemsd.co
#   dev:  http://localhost:3001
NEXT_PUBLIC_OPSCORE_URL=https://opscore.systemsd.co

# TimePro API base.
NEXT_PUBLIC_API_URL=http://localhost:4001
