{
  "manifest_version": 3,
  "name": "TimePro URL Tracker",
  "version": "0.1.0",
  "description": "Reports the active browser tab's domain to TimePro for URL time tracking.",
  "permissions": ["tabs", "idle", "storage", "alarms"],
  "host_permissions": [
    "http://localhost:4001/*",
    "https://api.timepro.app/*",
    "http://localhost:3000/*",
    "https://app.timepro.app/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*", "https://app.timepro.app/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_popup": "popup.html", "default_title": "TimePro URL Tracker" }
}
