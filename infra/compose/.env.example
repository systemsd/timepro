# Compose variable substitution for docker-compose.prod.yml.
# Copy to `.env` (gitignored) and fill in real values on the host.
# These feed ${...} in the compose file: Postgres creds + the web build args.

# --- Postgres (the container; user is superuser → can CREATE EXTENSION) ---
POSTGRES_USER=timepro
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=timepro

# --- Web build args (Next inlines these at BUILD time, not runtime) ---
NEXT_PUBLIC_API_URL=https://api.timepro.systemsd.co
NEXT_PUBLIC_OPSCORE_URL=https://opscore.systemsd.co
