# Runtime env for the api (and migrate) containers.
# Copy to `envs/api.env` (gitignored) and fill in real secrets on the host.
# Only keys read by apps/api/src/config.ts are listed — extras are ignored.
#
# NOTE: DATABASE_URL is injected by the compose file from POSTGRES_* in .env,
# so it's intentionally NOT set here.

NODE_ENV=production
LOG_LEVEL=info

# --- Server bind / public URLs ---
API_HOST=0.0.0.0
API_PORT=4001
API_PUBLIC_URL=https://api.timepro.systemsd.co
WEB_PUBLIC_URL=https://timepro.systemsd.co
# Comma-separated allowed CORS origins (the web app's public origin).
API_CORS_ORIGINS=https://timepro.systemsd.co

# --- Required secrets (boot fails if missing / too short) ---
# >= 32 chars. Generate: openssl rand -hex 32
JWT_SIGNING_KEY_PRIMARY=CHANGE_ME_min_32_chars_openssl_rand_hex_32
# >= 16 chars. Generate: openssl rand -hex 16
AUTH_INTERNAL_SHARED_SECRET=CHANGE_ME_min_16_chars

# --- Redis: declared-but-unused at current scale (no client dials it).
# Placeholder satisfies the required env var; no Redis container runs. ---
REDIS_URL=redis://disabled:6379

# --- OpsCore integration (must match OpsCore prod's TIMEPRO_* secrets) ---
OPSCORE_API_URL=https://opscore.systemsd.co
OPSCORE_HANDOFF_SECRET=CHANGE_ME_match_opscore_TIMEPRO_HANDOFF_SECRET
OPSCORE_API_KEY=CHANGE_ME_match_opscore_TIMEPRO_API_KEY
# Slug/name of the TimePro org JIT-created on the first OpsCore login.
OPSCORE_ORG_SLUG=demo
OPSCORE_ORG_NAME=Systemsd

# --- Screenshot storage (mounted named volume; nonroot-owned) ---
STORAGE_DIR=/data/screenshots
